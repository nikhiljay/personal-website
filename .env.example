# Kavi trip calendar (ICS URL)
KAVI_TRIP_CALENDAR_ICAL_URL=

# Vercel AI Gateway — required for local dev; OIDC auth on Vercel production
AI_GATEWAY_API_KEY=

# Google Places API (New) — for Ask AI star ratings / review counts
GOOGLE_PLACES_API_KEY=

# Braintrust — AI tracing and evals
# Local: copy BRAINTRUST_API_KEY from .env.braintrust after wizard setup.
# Vercel (Marketplace drain): no API key required — ensure a Braintrust drain is
# configured for this project in Vercel Integrations; instrumentation uses @vercel/otel.
# Vercel (SDK path): set all three vars below on Production + Preview.
BRAINTRUST_API_KEY=
# Optional — omit to resolve by project name. Current kavi-nyc-trip project:
BRAINTRUST_PROJECT_ID=61cbeabf-3270-4c2e-bcd7-59f492fb5c07
BRAINTRUST_PROJECT_NAME=kavi-nyc-trip
