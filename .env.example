# Kavi trip calendar (ICS URL)
KAVI_TRIP_CALENDAR_ICAL_URL=

# Vercel AI Gateway — required for local dev; OIDC auth on Vercel production
AI_GATEWAY_API_KEY=

# Google Places API (New) — for Ask AI star ratings / review counts
GOOGLE_PLACES_API_KEY=

# Braintrust — AI tracing and evals (copy from .env.braintrust after wizard setup)
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT_NAME=braintrust-aqua-ball
# Disable Braintrust's auto AI SDK plugin; we register v7 telemetry manually instead.
BRAINTRUST_DISABLE_INSTRUMENTATION=aisdk
